# KUS Suite Extension — Variables de entorno
# Copia este archivo como .env y completa los valores

# API Keys para analytics (plan Influencer)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
TIKTOK_API_KEY=your_tiktok_api_key

# KUS License Panel URL
KUS_LICENSE_PANEL_URL=https://luisitoys12.github.io/kus-license-panel

# Entorno
NODE_ENV=development
